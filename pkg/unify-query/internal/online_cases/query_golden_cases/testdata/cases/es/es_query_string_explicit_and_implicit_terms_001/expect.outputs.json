[
  {"backend": "elasticsearch", "method": "GET", "path": "/golden_es_and_terms"},
  {
    "backend": "elasticsearch",
    "method": "POST",
    "path": "/golden_es_and_terms/_search",
    "body": {
      "_source": {"includes": ["_time", "_value", "message"]},
      "from": 0,
      "query": {
        "bool": {
          "filter": [
            {"range": {"dtEventTimeStamp": {"format": "epoch_second", "from": 1784701776, "include_lower": true, "include_upper": true, "to": 1784702076}}},
            {
              "bool": {
                "must": [
                  {"query_string": {"analyze_wildcard": true, "fields": ["*", "__*"], "lenient": true, "query": "alpha"}},
                  {"query_string": {"analyze_wildcard": true, "fields": ["*", "__*"], "lenient": true, "query": "beta"}},
                  {"query_string": {"analyze_wildcard": true, "fields": ["*", "__*"], "lenient": true, "query": "delta"}},
                  {"query_string": {"analyze_wildcard": true, "fields": ["*", "__*"], "lenient": true, "query": "gamma"}},
                  {"query_string": {"analyze_wildcard": true, "fields": ["*", "__*"], "lenient": true, "query": "theta"}}
                ]
              }
            }
          ]
        }
      },
      "size": 10,
      "sort": [{"dtEventTimeStamp": {"order": "asc", "unmapped_type": "date"}}]
    }
  }
]
