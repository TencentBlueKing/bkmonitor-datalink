[
  {"backend": "elasticsearch", "method": "GET", "path": "/golden_es_case_sensitive"},
  {
    "backend": "elasticsearch",
    "method": "POST",
    "path": "/golden_es_case_sensitive/_search",
    "body": {
      "_source": {"includes": ["_time", "_value", "message"]},
      "from": 0,
      "query": {
        "bool": {
          "filter": [
            {"range": {"dtEventTimeStamp": {"format": "epoch_second", "from": 1784701776, "include_lower": true, "include_upper": true, "to": 1784702076}}},
            {"bool": {"should": [{"wildcard": {"message": {"value": "*ERROR*"}}}, {"wildcard": {"message": {"value": "*Traceback*"}}}]}}
          ]
        }
      },
      "size": 10,
      "sort": [{"dtEventTimeStamp": {"order": "asc", "unmapped_type": "date"}}]
    }
  }
]
